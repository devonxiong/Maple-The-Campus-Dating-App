// Copy this file to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored so real keys never get committed.
//
// The Supabase anon key is a *public client* credential (it's protected by
// Row-Level Security), so shipping it inside the app binary is expected and safe.

// Supabase — used directly from the app for feed reads, swipes, matches, realtime.
MAPLE_SUPABASE_URL = https:/$()/YOUR-PROJECT.supabase.co
MAPLE_SUPABASE_ANON_KEY = your-anon-key

// Backend base — the deployed Next.js API (server routes: signup, otp, plan-date, ...).
// Note: xcconfig treats "//" as a comment, so we escape it as "/$()/".
MAPLE_API_BASE = https:/$()/www.maplemeet.ai

// Your Apple Developer Team ID (Membership page). Leave empty for now if unsigned.
DEVELOPMENT_TEAM =
